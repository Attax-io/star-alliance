{
  "harness_version": "1.0.0",
  "name": "Star Alliance",
  "description": "Personal AI harness — skills + members (agents) + arsenal (model offload) installed as one unit into a project's .claude/.",
  "components": {
    "skills": "star-alliance-skills/",
    "members": "star-alliance-members/",
    "arsenal": "star-alliance-arsenal/",
    "manifest": "domains.json"
  },
  "_note": "Bump harness_version on any release-worthy change.",
  "policy": {
    "_note": "Drives the proportional routing gate (guild-routing-gate.sh). The gate governs on TWO axes: stakes (reversibility/blast-radius) and size/novelty. Stakes ALWAYS wins over size — a one-line edit to a migration is small but high-stakes and must take the FULL gate + approval halt. Only a turn that is clearly-small AND clearly-low-stakes gets the LITE gate. Unknown → FULL (fail-safe). Edit this list, not the shell.",
    "stakes_keywords": [
      "migration", "migrate", "alter table", "drop table", "drop column",
      "rename", "git push", "force push", "force-push", "--force", "reset --hard",
      "prod", "production", "deploy", "release", "rm -rf", "delete", "truncate",
      "rls", "policy", "secret", "api key", "credential", "schema change",
      "mass edit", "all files", "every file", "across the repo", "rewrite all"
    ],
    "size_short_chars": 400,
    "size_small_signals": [
      "typo", "one line", "single line", "quick fix", "rename variable",
      "fix the", "tweak", "comment", "small change", "one-liner", "minor",
      "explain", "what is", "what's", "what are", "what does", "how does",
      "how do i", "how do you", "why does", "why is", "recap", "summarize",
      "summary", "show me", "describe", "in plain", "tell me", "walk me through",
      "clarify", "read the", "look at", "list the", "is the", "are the", "does the"
    ],
    "size_large_signals": [
      "campaign", "audit", "build", "refactor", "feature", "multi", "phase",
      "migrate", "overhaul", "redesign", "architecture", "plan", "ship",
      "implement", "all phases", "across"
    ],
    "chat_signals": [
      "hi", "hello", "thanks", "thank you", "ok", "okay", "got it", "gotcha",
      "right", "yes", "no", "sure", "great", "good", "what is", "what's",
      "what does", "what do", "how does", "how do", "why does", "why is",
      "explain", "tell me", "show me", "describe", "recap", "summarize",
      "in plain english"
    ]
  },
  "swarm_caps": { "max_swarm": 5, "max_total_workers": 12 }
}
