#!/usr/bin/env python3
"""
sa — Star Alliance guild CLI (Phase 3).

Single-file, stdlib-only. No pip deps, no venv. Bridges local hooks/state to
the `guild` schema in Supabase over PostgREST (HTTPS + JWT).

Design contract (see /Users/atta/.claude/plans/before-fixing-upgrading-the-star-radiant-mitten.md):
  - Reads never touch the network in-session (Claude Code loads local files only).
  - Writes never block sessions (outbox write-ahead log, flushed opportunistically).
  - Every network call fails OPEN: short timeout, try/except, never raises to caller.
  - This file is import-safe: `python3 -c "import importlib.util; ..."` loads it as
    a module without executing main() (guarded by `if __name__ == "__main__"`).
"""
import sys
import os
import json
import hashlib
import hmac
import base64
import time
import uuid
import subprocess
import urllib.request
import urllib.error
import urllib.parse
from pathlib import Path

# ── Root self-location ──────────────────────────────────────────────────────
