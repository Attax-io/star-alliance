FLUSH_BUDGET_S = 3.0


def device_id_slug():
    """Stable per-machine id: 'mac-' + the OS user. Same convention used by
    turn-cost.py, spawn-log.py, and tools/backfill_guild.py — never derive
    this independently."""
    import getpass
    try:
        return "mac-" + getpass.getuser()
    except Exception:
        return "mac-unknown"


# ── HS256 JWT minting (stdlib hmac/hashlib/base64) ──────────────────────────

def _b64url(data: bytes) -> str:
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode("ascii")


def _b64url_decode(s: str) -> bytes:
    pad = "=" * (-len(s) % 4)
    return base64.urlsafe_b64decode(s + pad)


def mint_jwt(secret: str, role: str = "guild_agent", iss: str = "star-alliance",
             years: int = 10, now: float = None) -> str:
    """Mint an HS256 JWT locally. The secret is used only in-process and never
    persisted — caller discards it immediately after calling this."""
    now = now if now is not None else time.time()
    header = {"alg": "HS256", "typ": "JWT"}
    payload = {
        "role": role,
        "iss": iss,
        "iat": int(now),
        "exp": int(now + years * 365 * 24 * 3600),
    }
    header_b64 = _b64url(json.dumps(header, separators=(",", ":")).encode())
    payload_b64 = _b64url(json.dumps(payload, separators=(",", ":")).encode())
    signing_input = f"{header_b64}.{payload_b64}".encode()
    sig = hmac.new(secret.encode(), signing_input, hashlib.sha256).digest()
    sig_b64 = _b64url(sig)
    return f"{header_b64}.{payload_b64}.{sig_b64}"


def decode_jwt_unverified(token: str) -> dict:
    """Decode a JWT's payload without verifying (used by tests / doctor)."""
    parts = token.split(".")
    if len(parts) != 3:
        raise ValueError("not a JWT")
    return json.loads(_b64url_decode(parts[1]))


def verify_jwt(token: str, secret: str) -> bool:
    parts = token.split(".")
    if len(parts) != 3:
        return False
    header_b64, payload_b64, sig_b64 = parts
    signing_input = f"{header_b64}.{payload_b64}".encode()
    expected = hmac.new(secret.encode(), signing_input, hashlib.sha256).digest()
    actual = _b64url_decode(sig_b64)
    return hmac.compare_digest(expected, actual)


# ── Keychain (macOS `security`) ─────────────────────────────────────────────

def publishable_key() -> str:
    """Resolve the Supabase publishable (anon-safe) API key for the `apikey`
    header. NOT a secret — safe to print/log. Precedence: SA_PUBLISHABLE_KEY
    env > ~/.config/star-alliance/config.json {"publishable_key": "..."} >
    built-in default (this project's known publishable key)."""
    env_key = os.environ.get("SA_PUBLISHABLE_KEY")
    if env_key:
        return env_key
    try:
        if CLI_CONFIG.exists():
            cfg = json.loads(CLI_CONFIG.read_text())
            k = cfg.get("publishable_key")
            if k:
                return k
    except Exception:
        pass
    return DEFAULT_PUBLISHABLE_KEY


def ensure_cli_config():
    """Write config.json with the default publishable key if it doesn't
    exist yet, so `sa doctor` / `sa init` leave a discoverable, editable
    plain file. Never overwrites an existing file."""
    try:
        if not CLI_CONFIG.exists():
            CLI_CONFIG.parent.mkdir(parents=True, exist_ok=True)
            CLI_CONFIG.write_text(json.dumps(
                {"publishable_key": DEFAULT_PUBLISHABLE_KEY}, indent=2))
    except Exception as e:
        print(f"warning: could not write {CLI_CONFIG}: {e}", file=sys.stderr)


def keychain_store_jwt(jwt: str) -> bool:
    try:
        subprocess.run(
            ["security", "add-generic-password", "-U",
             "-s", KEYCHAIN_SERVICE, "-a", KEYCHAIN_ACCOUNT, "-w", jwt],
            check=True, capture_output=True, timeout=10,
        )
        return True
    except Exception as e:
        print(f"warning: keychain store failed: {e}", file=sys.stderr)
        return False


def keychain_read_jwt() -> str:
    env_jwt = os.environ.get("SA_GUILD_JWT")
    if env_jwt:
        return env_jwt
    try:
        r = subprocess.run(
            ["security", "find-generic-password", "-s", KEYCHAIN_SERVICE,
             "-a", KEYCHAIN_ACCOUNT, "-w"],
            check=True, capture_output=True, timeout=10, text=True,
        )
        return r.stdout.strip()
    except Exception:
        return ""


# ── Hash manifest (shared by push / seed / cursor) ──────────────────────────

def sha256_hex(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def hash_manifest(dir_path: Path) -> str:
    """Content hash over sorted (relpath, sha256(content)) manifest for a
    skill/member directory. Deterministic regardless of filesystem order."""
    dir_path = Path(dir_path)
    entries = []
    if dir_path.is_file():
        content = dir_path.read_bytes()
        entries.append((dir_path.name, sha256_hex(content)))
    else:
        for p in sorted(dir_path.rglob("*")):
            if p.is_file():
                rel = str(p.relative_to(dir_path))
                if "__pycache__" in rel or rel.startswith("."):
                    continue
                try:
                    content = p.read_bytes()
                except Exception:
                    continue
                entries.append((rel, sha256_hex(content)))
    entries.sort(key=lambda t: t[0])
    manifest_str = "\n".join(f"{rel}:{h}" for rel, h in entries)
    return sha256_hex(manifest_str.encode())


def build_files_payload(dir_path: Path) -> dict:
    """{relpath: content-string} (or {relpath: {"content_b64": "..."}} for
    binaries) for push_skill's p_files jsonb param. Confirmed live against
    prod 2026-07-12: the RPC does `jsonb_each(p_files)` on the TOP-LEVEL
    argument, so p_files must be a flat JSON *object* keyed by relpath —
    never a JSON array of {path, content, hash} descriptors (that shape
    raises 22023 "cannot call jsonb_each on a non-object"). There is no
    per-file hash column in guild.skill_files — content-hashing lives on
    guild.skills.content_hash / guild.skill_versions instead."""
    dir_path = Path(dir_path)
    files = {}
    for p in sorted(dir_path.rglob("*")):
        if not p.is_file():
            continue
        rel = str(p.relative_to(dir_path))
        if "__pycache__" in rel or rel.startswith("."):
            continue
        try:
            raw = p.read_bytes()
        except Exception:
            continue
        try:
            files[rel] = raw.decode("utf-8")
        except UnicodeDecodeError:
            files[rel] = {"content_b64": base64.b64encode(raw).decode("ascii")}
    return files


# ── SKILL.md frontmatter parsing (metadata for push, not the source of body) ──

def parse_skill_frontmatter(skill_dir: Path) -> dict:
    """Best-effort YAML-lite frontmatter parse from SKILL.md: name, description,
    metadata.version. Never raises — falls back to sane defaults.

    Delegates to the shared _fm_field/_fm_description/_fm_version helpers
    (defined further down this file) so this function inherits their YAML
    block-scalar handling (`description: >-`, `>`, `>+`, `|`, `|-`, `|+`
    followed by indented body lines) instead of re-implementing a single-line
    -only parser. Previously this duplicated a naive single-line parser that
    captured only the block-scalar indicator token (e.g. literally ">") and
    dropped the real multi-line description body — fixed 2026-07-12."""
    meta = {"name": skill_dir.name, "description": "", "version": "0.0.0"}
    md = skill_dir / "SKILL.md"
    if not md.exists():
        return meta
    try:
        text = md.read_text(encoding="utf-8")
    except Exception:
        return meta
    if not text.startswith("---"):
        return meta
    end = text.find("\n---", 3)
    if end == -1:
        return meta
    fm = text[3:end]
    name = _fm_field(fm, "name")
    if name:
        meta["name"] = name
    meta["description"] = _fm_description(fm)
    version = _fm_version(fm)
    if version:
        meta["version"] = version
    return meta


# ── Cursor state ─────────────────────────────────────────────────────────

def load_cursor() -> dict:
    if CURSOR_PATH.exists():
        try:
            return json.loads(CURSOR_PATH.read_text())
        except Exception:
            return {}
    return {}


def save_cursor(data: dict) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    CURSOR_PATH.write_text(json.dumps(data, indent=2, sort_keys=True))


# ── PostgREST client (fail-open) ────────────────────────────────────────────

class PostgrestError(Exception):
    def __init__(self, status, body):
        self.status = status
        self.body = body
        super().__init__(f"HTTP {status}: {body}")


def _headers(jwt: str, prefer: str = None) -> dict:
    # New Supabase api-key gateway: `apikey` must be a recognized project key
    # (the publishable key), NOT the minted guild JWT. The Bearer token stays
    # the minted guild_agent JWT — that is what supplies the `guild_agent`
    # role via the legacy JWT signing secret.
    h = {
        "apikey": publishable_key(),
        "Authorization": f"Bearer {jwt}",
        "Accept-Profile": "guild",
        "Content-Profile": "guild",
        "Content-Type": "application/json",
    }
    if prefer:
        h["Prefer"] = prefer
    return h


def pg_request(method: str, path: str, jwt: str, params: dict = None,
               body=None, prefer: str = None, timeout: float = DEFAULT_TIMEOUT):
    """Raw PostgREST call. Raises PostgrestError/URLError — caller decides
    fail-open behavior. Never used bare in a hook path."""
    url = POSTGREST_BASE + path.lstrip("/")
    if params:
        url += "?" + urllib.parse.urlencode(params)
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method,
                                  headers=_headers(jwt, prefer))
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        raw = resp.read()
        if not raw:
            return None
        try:
            return json.loads(raw)
        except Exception:
            return raw.decode("utf-8", "replace")


def pg_request_safe(method: str, path: str, jwt: str, **kw):
    """Never raises. Returns (ok, result_or_error_str)."""
    try:
        return True, pg_request(method, path, jwt, **kw)
    except urllib.error.HTTPError as e:
        try:
            body = e.read().decode("utf-8", "replace")
        except Exception:
            body = str(e)
        return False, f"HTTP {e.code}: {body}"
    except Exception as e:
        return False, str(e)


# ── outbox (write-ahead log) ────────────────────────────────────────────────

def outbox_append(table: str, payload: dict, client_uuid: str = None) -> dict:
    """Append one row to the local outbox. Never touches the network."""
    row = {
        "table": table,
        "client_uuid": client_uuid or str(uuid.uuid4()),
        "payload": payload,
    }
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with open(OUTBOX_PATH, "a", encoding="utf-8") as f:
        f.write(json.dumps(row, separators=(",", ":")) + "\n")
    return row


def outbox_read_lines() -> list:
    if not OUTBOX_PATH.exists():
        return []
    lines = []
    with open(OUTBOX_PATH, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                lines.append(line)
    return lines


def outbox_flush(jwt: str = None, budget_s: float = FLUSH_BUDGET_S) -> dict:
    """Batch-POST outbox rows to their tables, grouped by table, with
    Prefer: resolution=ignore-duplicates. Shrinks the log to just the
    still-pending rows on success, keeps everything on failure. ALWAYS
    returns a summary dict; never raises."""
    summary = {"flushed": 0, "kept": 0, "errors": [], "reachable": False}
    lines = outbox_read_lines()
    if not lines:
        return summary

    jwt = jwt or keychain_read_jwt()
    if not jwt:
        summary["errors"].append("no JWT available")
        summary["kept"] = len(lines)
        return summary

    start = time.time()
    by_table = {}
    for raw in lines:
        try:
            row = json.loads(raw)
        except Exception:
            continue
        t = row.get("table")
        by_table.setdefault(t, []).append(row)

    failed_raw_lines = []
    for table, rows in by_table.items():
        if time.time() - start > budget_s:
            failed_raw_lines.extend(json.dumps(r, separators=(",", ":")) for r in rows)
            summary["errors"].append(f"budget exceeded before flushing {table}")
            continue
        payload = [r["payload"] | {"client_uuid": r["client_uuid"]} for r in rows]
        # PostgREST's bulk insert requires every object in the JSON array to
        # carry the SAME keys ("All object keys must match", PGRST102) — a
        # straggler row from an older producer schema (missing a column
        # later rows gained) breaks the whole batch. Normalize to the union
        # of keys across the batch, filling absent ones with None, so one
        # stale row can't block every fresh row behind it in the same table.
        all_keys = set()
        for row in payload:
            all_keys.update(row.keys())
        if any(set(row.keys()) != all_keys for row in payload):
            payload = [{k: row.get(k) for k in all_keys} for row in payload]
        remaining = max(0.1, budget_s - (time.time() - start))
        ok, result = pg_request_safe(
            "POST", table, jwt, body=payload,
            prefer="resolution=ignore-duplicates,return=minimal",
            timeout=remaining,
        )
        if ok:
            summary["flushed"] += len(rows)
            summary["reachable"] = True
        else:
            failed_raw_lines.extend(json.dumps(r, separators=(",", ":")) for r in rows)
            summary["errors"].append(f"{table}: {result}")

    summary["kept"] = len(failed_raw_lines)
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        if failed_raw_lines:
            with open(OUTBOX_PATH, "w", encoding="utf-8") as f:
                f.write("\n".join(failed_raw_lines) + "\n")
        else:
            OUTBOX_PATH.write_text("")
    except Exception as e:
        summary["errors"].append(f"rewrite failed: {e}")

    return summary


