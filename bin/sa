PROJECT_REF = "bqgrpnsvplvicnmzxwkm"
POSTGREST_BASE = f"https://{PROJECT_REF}.supabase.co/rest/v1/"
KEYCHAIN_SERVICE = "star-alliance-guild"
KEYCHAIN_ACCOUNT = PROJECT_REF

STATE_DIR = ROOT / ".claude" / "state"
CURSOR_PATH = STATE_DIR / "sa-cursor.json"
OUTBOX_PATH = STATE_DIR / "outbox.jsonl"
CONSUMERS_CONFIG = Path.home() / ".config" / "star-alliance" / "consumers.json"
CLI_CONFIG = Path.home() / ".config" / "star-alliance" / "config.json"
DEFAULT_PUBLISHABLE_KEY = "sb_publishable_211wI3-f4Z34HJNgwYdlOw_3xNke-B0"
CLI_VERSION = "0.3.0"

SKILLS_DIR = ROOT / "star-alliance-skills"
MEMBERS_DIR = ROOT / "star-alliance-members"
