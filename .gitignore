__pycache__/
*.pyc

# runtime safety backups from the control-panel write-through
*.bak

# macOS Finder metadata — per-device, never sync
.DS_Store
**/.DS_Store

# Runtime delegation-ledger data (real token spend per doer call)
star-alliance-arsenal/usage-log.jsonl

# Dashboard runtime artifacts — regenerated live by serve.cjs, never source
guild-data.js
guild-data.json
skill-md.js
workflow-md.js

# Workflow-runner runtime output (artifacts, signoffs, summaries)
runs/

# dashboard launcher runtime log
.claude/serve.out

# Tauri desktop app — build artifacts (never commit the node sidecar or Rust target)
desktop/node_modules/
desktop/src-tauri/target/
desktop/src-tauri/gen/
desktop/src-tauri/binaries/node-*

# Evolution Engine — local kill switch, never committed
evolution/DISARMED

# Hermes runtime state (profiles/, sessions, caches — not source)
state/

# MCP server — venv (never commit the virtual environment)
mcp/.venv/

# wire_skill.py — one-off scratchpad venv for Pillow thumbnail generation
.scratch-thumbs-venv/

# Per-project skill mirror — device copy, regenerated by skillsmith sync; never source-of-truth
.claude/skills/
