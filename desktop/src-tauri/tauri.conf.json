{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Star Alliance",
  "version": "0.1.0",
  "identifier": "io.attax.star-alliance",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Star Alliance — Mission Console",
        "label": "main",
        "url": "http://localhost:4178/",
        "width": 1320,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false,
        "backgroundColor": "#07090f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/node"]
  }
}
